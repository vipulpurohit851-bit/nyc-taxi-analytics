              <attribute datatype='string' name='DebugWireType'>&quot;SQL_C_DOUBLE&quot;</attribute>
            </attributes>
            <object-id>[MASTER_ANALYTICS (NYC_TAXI_DB.MASTER_ANALYTICS)_0A34A7DD62CE423CB6E5F7E4F32C2128]</object-id>
          </metadata-record>
        </metadata-records>
      </connection>
      <aliases enabled='yes' />
      <column caption='Hour Label' datatype='string' name='[Calculation_0853501695381504]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [HOUR] = 0 THEN &quot;12AM&quot;&#13;&#10;ELSEIF [HOUR]&lt;12 THEN STR([HOUR])+&quot;AM&quot;&#13;&#10;ELSEIF [HOUR]= 12 THEN &quot;12PM&quot;&#13;&#10;ELSE STR([HOUR]-12)+&quot;PM&quot;&#13;&#10;END' />
      </column>
      <column caption='Hour Group' datatype='string' name='[Calculation_0853501702033411]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='case[HOUR]&#13;&#10;when 0 THEN &quot;12AM&quot;&#13;&#10;when 3 THEN &quot;3AM&quot;&#13;&#10;when 6 THEN &quot;6AM&quot;&#13;&#10;WHEN 9 THEN &quot;9AM&quot;&#13;&#10;WHEN 12 THEN &quot;12PM&quot;&#13;&#10;WHEN  15 THEN &quot;3PM&quot;&#13;&#10;WHEN  18 THEN &quot;6PM&quot;&#13;&#10;WHEN  21 THEN &quot;9PM&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Trips' datatype='integer' name='[Calculation_2080281158668295]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([VENDORID])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_2080281159577608]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TOTAL_AMOUNT])' />
      </column>
      <column caption='Avg Distance' datatype='real' name='[Calculation_2080281159692297]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([TRIP_DISTANCE])' />
      </column>
      <column caption='Avg Fare' datatype='real' name='[Calculation_2080281159794698]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([FARE_AMOUNT])' />
      </column>
      <column caption='Total Passengers' datatype='real' name='[Calculation_2080281159880715]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([PASSENGER_COUNT])' />
      </column>
      <column caption='Avg Tip' datatype='real' name='[Calculation_2080281160093708]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([TIP_AMOUNT])' />
      </column>
      <column caption='Revenue Per Trip' datatype='real' name='[Calculation_2080281162706957]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TOTAL_AMOUNT])/COUNT([VENDORID])' />
      </column>
      <column caption='Revenue Per Mile' datatype='real' name='[Calculation_2080281164763151]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TOTAL_AMOUNT])/SUM([TRIP_DISTANCE])' />
      </column>
