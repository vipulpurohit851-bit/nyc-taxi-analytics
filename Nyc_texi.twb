    <worksheet name='Rush Hour vs Non-Rush Hour Demand'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='MASTER_ANALYTICS (NYC_TAXI_DB.MASTER_ANALYTICS) (NYC_SCHEMA)' name='federated.1gqoiu10hzd73p16axawn1ip6ucj' />
          </datasources>
          <datasource-dependencies datasource='federated.1gqoiu10hzd73p16axawn1ip6ucj'>
            <column caption='Hour Label' datatype='string' name='[Calculation_0853501695381504]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [HOUR] = 0 THEN &quot;12AM&quot;&#13;&#10;ELSEIF [HOUR]&lt;12 THEN STR([HOUR])+&quot;AM&quot;&#13;&#10;ELSEIF [HOUR]= 12 THEN &quot;12PM&quot;&#13;&#10;ELSE STR([HOUR]-12)+&quot;PM&quot;&#13;&#10;END' />
            </column>
